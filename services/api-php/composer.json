{
  "name": "birdie/api",
  "description": "Korean Learning Platform API",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "firebase/php-jwt": "^6.10",
    "vlucas/phpdotenv": "^5.6",
    "ext-pdo": "*",
    "ext-json": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "serve": "php -S localhost:8080 -t public",
    "migrate": "php tools/migrate.php",
    "import": "php tools/import-content.php"
  }
}
