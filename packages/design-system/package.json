{
  "name": "@reterics/birdie-ui",
  "version": "0.1.1",
  "private": false,
  "description": "Birdie UI design system for My Korean Birdie.",
  "license": "MIT",
  "author": {
    "name": "Attila Reterics",
    "email": "reterics.attila@gmail.com",
    "url": "https://reterics.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Reterics/project_v9_korea.git",
    "directory": "packages/design-system"
  },
  "bugs": {
    "url": "https://github.com/Reterics/project_v9_korea/issues"
  },
  "homepage": "https://github.com/Reterics/project_v9_korea/tree/main/packages/design-system",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "public",
    "quiz.png",
    "src/styles/theme.css",
    "src/types/assets.d.ts"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme": "./src/styles/theme.css",
    "./assets/*": "./public/*",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@storybook/react-vite": "^10.2.16",
    "@tailwindcss/vite": "^4.2.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/addon-onboarding": "^10.2.16",
    "@storybook/addon-vitest": "^10.2.16",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.7",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "playwright": "^1.58.2",
    "storybook": "^10.2.16",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.400.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
